<?xml version="1.0"?>
<robot name="my_robot">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.6 0.4 0.2"/>   <!-- 长 宽 高，单位米，空格分隔 -->
      </geometry>
        <material name="blue"/>    <!-- 可选：加个 material 定义颜色 -->
            <color rgba="0 0 1 1"/>   <!-- 蓝色，最后一个参数是透明度 -->
        </material>
    </visual>
  </link>

</robot>